# stage_tex - standalone Quartus timing project for tsp_shade_pp's TEX stage
# (4 tex_fetch_pp fetchers + 2 tex_cache_4p_1c caches + real DDR arbiter).
set_global_assignment -name FAMILY "Cyclone V"
set_global_assignment -name DEVICE 5CSEBA6U23I7
set_global_assignment -name LAST_QUARTUS_VERSION "17.0.0 Standard Edition"

set_global_assignment -name PROJECT_OUTPUT_DIRECTORY output_files
set_global_assignment -name NUM_PARALLEL_PROCESSORS ALL
set_global_assignment -name OPTIMIZATION_MODE "HIGH PERFORMANCE EFFORT"
set_global_assignment -name OPTIMIZATION_TECHNIQUE SPEED

set_global_assignment -name VERILOG_MACRO "SYNTHESIS=1"

set_global_assignment -name SEARCH_PATH .
set_global_assignment -name SEARCH_PATH ../../rtl/tsp/gen

# package first
set_global_assignment -name SYSTEMVERILOG_FILE ../../rtl/tsp/tsp_pkg.sv
# HPS DDR3 bridge
set_global_assignment -name SYSTEMVERILOG_FILE ../../rtl/mister/f2sdram_safe_terminator.sv
set_global_assignment -name SYSTEMVERILOG_FILE ../../rtl/mister/sysmem.sv
set_global_assignment -name SYSTEMVERILOG_FILE ../../rtl/mister/ddram.sv
# texture fetch/decode/addr/cache
set_global_assignment -name SYSTEMVERILOG_FILE ../../rtl/tsp/tex_decode.sv
set_global_assignment -name SYSTEMVERILOG_FILE ../../rtl/tsp/tex_addr.sv
set_global_assignment -name SYSTEMVERILOG_FILE ../../rtl/tsp/tex_fetch_pp.sv
set_global_assignment -name SYSTEMVERILOG_FILE ../../rtl/tsp/tex_cache_4p_1c.sv
# the TEX-stage unit (4 tex_fetch_pp + 2 tex_cache_4p_1c)
set_global_assignment -name SYSTEMVERILOG_FILE ../../rtl/tsp/tex_unit.sv
# harness top
set_global_assignment -name SYSTEMVERILOG_FILE stage_tex.sv
set_global_assignment -name SDC_FILE stage.sdc

set_global_assignment -name TOP_LEVEL_ENTITY stage_tex

set_instance_assignment -name PARTITION_HIERARCHY root_partition -to | -section_id Top
set_global_assignment -name PARTITION_NETLIST_TYPE SOURCE -section_id Top
set_global_assignment -name PARTITION_FITTER_PRESERVATION_LEVEL PLACEMENT_AND_ROUTING -section_id Top
set_global_assignment -name PARTITION_COLOR 16764057 -section_id Top