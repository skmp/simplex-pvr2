# --------------------------------------------------------------------------
# timming_tsp_setup_min - standalone Quartus project to place-and-route + time the
# WHOLE tsp_setup_min unit (via the timming_tsp_setup_min harness). Sibling to
# timming_tsp_shade_v2_pp / stage_all, but tsp_setup_min is a plain clk/reset unit
# (no DDR bridge), so this uses a real top-level `clk` pin.
#
# Device: Cyclone V 5CSEBA6U23I7 (Terasic DE10-Nano / MiSTer).
# Build:  cd timming_tests/timming_tsp_setup_min && quartus_sh --flow compile timming_tsp_setup_min
# Fmax:   output_files/timming_tsp_setup_min.sta.rpt
# --------------------------------------------------------------------------

set_global_assignment -name FAMILY "Cyclone V"
set_global_assignment -name DEVICE 5CSEBA6U23I7
set_global_assignment -name LAST_QUARTUS_VERSION "17.0.0 Standard Edition"

set_global_assignment -name PROJECT_OUTPUT_DIRECTORY output_files
set_global_assignment -name NUM_PARALLEL_PROCESSORS ALL
set_global_assignment -name OPTIMIZATION_MODE "HIGH PERFORMANCE EFFORT"
set_global_assignment -name OPTIMIZATION_TECHNIQUE SPEED

set_global_assignment -name QIP_FILE timming_tsp_setup_min.files.qip
set_global_assignment -name SDC_FILE stage.sdc

set_global_assignment -name VERILOG_MACRO "SYNTHESIS=1"

set_global_assignment -name SEARCH_PATH .
set_global_assignment -name SEARCH_PATH ../../rtl/tsp/gen

set_global_assignment -name TOP_LEVEL_ENTITY timming_tsp_setup_min
set_global_assignment -name PARTITION_NETLIST_TYPE SOURCE -section_id Top
set_global_assignment -name PARTITION_FITTER_PRESERVATION_LEVEL PLACEMENT_AND_ROUTING -section_id Top
set_global_assignment -name PARTITION_COLOR 16764057 -section_id Top



set_instance_assignment -name PARTITION_HIERARCHY root_partition -to | -section_id Top